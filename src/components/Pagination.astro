---
interface Props {
  currentPage: number;
  lastPage: number;
  prevUrl: string | undefined;
  nextUrl: string | undefined;
  baseUrl: string;
}

const { currentPage, lastPage, prevUrl, nextUrl, baseUrl } = Astro.props;

function pageUrl(n: number): string {
  return n === 1 ? baseUrl : `${baseUrl}${n}/`;
}

function getPageWindow(current: number, total: number, size = 5): number[] {
  if (total <= size) return Array.from({ length: total }, (_, i) => i + 1);
  let start = Math.max(1, current - Math.floor(size / 2));
  let end = Math.min(total, start + size - 1);
  if (end - start < size - 1) start = Math.max(1, end - size + 1);
  return Array.from({ length: end - start + 1 }, (_, i) => start + i);
}

const pageNums = getPageWindow(currentPage, lastPage);
---

{lastPage > 1 && (
  <div class="bg-white border-t border-gray-100">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-12 h-[72px] flex items-center justify-center">
      <div class="flex items-center justify-between w-full">

        <!-- Previous -->
        {prevUrl ? (
          <a
            href={prevUrl}
            class="inline-flex items-center gap-1.5 h-9 px-3.5 rounded-md border border-gray-300 bg-white text-sm text-gray-500 hover:border-navy hover:text-navy transition-colors whitespace-nowrap"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>
            Previous
          </a>
        ) : (
          <span class="inline-flex items-center gap-1.5 h-9 px-3.5 rounded-md border border-gray-200 bg-white text-sm text-gray-300 select-none whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>
            Previous
          </span>
        )}

        <!-- Page numbers -->
        <div class="flex items-center gap-0.5">
          {pageNums.map(n => (
            n === currentPage ? (
              <span class="w-9 h-9 flex items-center justify-center rounded-md text-sm font-semibold text-white bg-navy">
                {n}
              </span>
            ) : (
              <a
                href={pageUrl(n)}
                class="w-9 h-9 flex items-center justify-center rounded-md text-sm text-gray-500 hover:bg-gray-100 hover:text-navy transition-colors"
              >
                {n}
              </a>
            )
          ))}
        </div>

        <!-- Next -->
        {nextUrl ? (
          <a
            href={nextUrl}
            class="inline-flex items-center gap-1.5 h-9 px-3.5 rounded-md border border-gray-300 bg-white text-sm font-medium text-gray-900 hover:border-navy hover:text-navy transition-colors whitespace-nowrap"
          >
            Next
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        ) : (
          <span class="inline-flex items-center gap-1.5 h-9 px-3.5 rounded-md border border-gray-200 bg-white text-sm font-medium text-gray-300 select-none whitespace-nowrap">
            Next
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
          </span>
        )}

      </div>
    </div>
  </div>
)}
