---
---

<div
  id="search-modal"
  class="hidden fixed inset-0 z-50 overflow-y-auto"
  role="dialog"
  aria-modal="true"
  aria-label="Site search"
>
  <div id="search-backdrop" class="fixed inset-0 bg-black/60 backdrop-blur-sm"></div>

  <div class="relative flex justify-center px-4 pt-[12vh] pb-10">
    <div class="w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden">

      <!-- Input row -->
      <div class="flex items-center gap-3 px-4 border-b border-gray-100">
        <svg class="shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search articles…"
          autocomplete="off"
          spellcheck="false"
          class="flex-1 h-14 text-base text-gray-900 placeholder:text-gray-400 outline-none bg-transparent"
        />
        <div class="flex items-center gap-2 shrink-0">
          <kbd class="hidden sm:inline text-xs text-gray-400 border border-gray-200 rounded px-1.5 py-0.5">Esc</kbd>
          <button id="search-close" aria-label="Close search" class="text-gray-400 hover:text-navy transition-colors p-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto"></div>

    </div>
  </div>
</div>

<script>
  let pagefind: any = null;
  let debounce: ReturnType<typeof setTimeout>;

  async function initPagefind() {
    if (pagefind) return;
    try {
      pagefind = await import('/pagefind/pagefind.js' as any);
      await pagefind.init();
    } catch {
      pagefind = null;
    }
  }

  async function runSearch(query: string) {
    const el = document.getElementById('search-results')!;
    if (!query.trim()) { el.innerHTML = ''; return; }

    if (!pagefind) {
      el.innerHTML = '<p class="px-5 py-4 text-sm text-gray-400">Search is temporarily unavailable.</p>';
      return;
    }

    const search = await pagefind.search(query);

    if (search.results.length === 0) {
      el.innerHTML = '<p class="px-5 py-4 text-sm text-gray-400">No results for <strong class="text-gray-700">' + query + '</strong>.</p>';
      return;
    }

    const data = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));

    el.innerHTML = data.map((d: any) => `
      <a href="${d.url}" class="flex items-start gap-4 px-5 py-4 hover:bg-gray-50 transition-colors border-b border-gray-50 last:border-0" id="search-result-link">
        ${d.meta?.image ? `<img src="${d.meta.image}" alt="" class="w-14 h-14 rounded-lg object-cover shrink-0 bg-gray-100" loading="lazy">` : ''}
        <div class="min-w-0 flex-1">
          <p class="font-semibold text-navy text-sm leading-snug mb-1 line-clamp-1">${d.meta?.title ?? ''}</p>
          <p class="text-xs text-gray-500 leading-relaxed line-clamp-2">${d.excerpt}</p>
        </div>
      </a>
    `).join('');

    // close modal when a result is clicked
    el.querySelectorAll('#search-result-link').forEach(a => {
      a.addEventListener('click', closeSearch);
    });
  }

  function openSearch() {
    document.getElementById('search-modal')!.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    const input = document.getElementById('search-input') as HTMLInputElement;
    input.focus();
    initPagefind();
  }

  function closeSearch() {
    document.getElementById('search-modal')!.classList.add('hidden');
    document.body.style.overflow = '';
    (document.getElementById('search-input') as HTMLInputElement).value = '';
    document.getElementById('search-results')!.innerHTML = '';
  }

  document.getElementById('search-btn')?.addEventListener('click', openSearch);
  document.getElementById('search-close')?.addEventListener('click', closeSearch);
  document.getElementById('search-backdrop')?.addEventListener('click', closeSearch);

  document.getElementById('search-input')?.addEventListener('input', (e) => {
    clearTimeout(debounce);
    debounce = setTimeout(() => runSearch((e.target as HTMLInputElement).value), 200);
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
    if (e.key === 'Escape') closeSearch();
  });
</script>
