---
---

<div
  id="search-modal"
  class="hidden fixed inset-0 z-50 overflow-y-auto"
  role="dialog"
  aria-modal="true"
  aria-label="Site search"
>
  <!-- Backdrop -->
  <div id="search-backdrop" class="fixed inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div class="relative flex justify-center px-4 pt-[12vh] pb-10">
    <div class="w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden">

      <div class="flex items-center justify-between px-5 py-3.5 border-b border-gray-100">
        <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Search</span>
        <div class="flex items-center gap-3">
          <span class="hidden sm:flex items-center gap-1 text-xs text-gray-400">
            <kbd class="border border-gray-200 rounded px-1.5 py-0.5">⌘K</kbd>
            <span>to open</span>
            <kbd class="border border-gray-200 rounded px-1.5 py-0.5 ml-1">Esc</kbd>
            <span>to close</span>
          </span>
          <button id="search-close" aria-label="Close search" class="text-gray-400 hover:text-navy transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>
      </div>

      <div id="pagefind-search" class="p-3 min-h-[80px]"></div>

    </div>
  </div>
</div>

<style is:global>
  #pagefind-search {
    --pagefind-ui-primary: #062451;
    --pagefind-ui-font: 'Inter', sans-serif;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-border: #e5e7eb;
    --pagefind-ui-text: #111827;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-tag: #f3f4f6;
  }
  #pagefind-search .pagefind-ui__search-input {
    border-radius: 8px !important;
    font-family: 'Inter', sans-serif !important;
  }
  #pagefind-search .pagefind-ui__result-link {
    color: #062451 !important;
  }
  #pagefind-search .pagefind-ui__button {
    background: linear-gradient(135deg, #f78745, #f85026) !important;
    color: #fff !important;
    border: none !important;
  }
</style>

<script>
  let initialized = false;

  async function openSearch() {
    const modal = document.getElementById('search-modal')!;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    if (!initialized) {
      initialized = true;

      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(link);

      try {
        // @ts-ignore — generated at build time, Vite must not resolve this
        const { PagefindUI } = await import(/* @vite-ignore */ '/pagefind/pagefind-ui.js');
        new PagefindUI({
          element: '#pagefind-search',
          showImages: true,
          showEmptyFilters: false,
          resetStyles: false,
          excerptLength: 25,
        });
      } catch {
        document.getElementById('pagefind-search')!.innerHTML =
          '<p class="p-4 text-sm text-gray-400">Search is available after running <code class="bg-gray-100 px-1 rounded text-navy">npm run build</code>.</p>';
      }
    }

    setTimeout(() => {
      document.querySelector<HTMLInputElement>('.pagefind-ui__search-input')?.focus();
    }, 80);
  }

  function closeSearch() {
    document.getElementById('search-modal')!.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.getElementById('search-btn')?.addEventListener('click', openSearch);
  document.getElementById('search-close')?.addEventListener('click', closeSearch);
  document.getElementById('search-backdrop')?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape') closeSearch();
  });
</script>
