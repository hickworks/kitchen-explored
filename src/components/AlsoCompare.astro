---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <div class="max-w-[1344px] mx-auto px-6 lg:px-12 pb-4">
    <div class="rounded-xl border border-gray-100 bg-gray-50 px-6 py-5">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Also compare</p>
      <ul class="space-y-2">
        {posts.map(p => (
          <li>
            <a
              href={`/posts/${p.id}/`}
              class="inline-flex items-center gap-2 text-sm font-medium text-navy hover:text-orange-start transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" class="shrink-0 opacity-40"><path d="m9 18 6-6-6-6"/></svg>
              {p.data.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
)}
