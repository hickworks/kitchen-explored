---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const featured = allPosts.filter(p => p.data.featured).slice(0, 3);
const latest = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 9);
---

<BaseLayout title="Home" description="Kitchen product comparisons and reviews — blenders, cookware, knives, ovens, and more.">

  <!-- Hero -->
  <section class="bg-navy text-white py-20 px-4 text-center">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Find Your Perfect Kitchen Tool</h1>
    <p class="text-white/70 text-lg max-w-xl mx-auto">
      Side-by-side comparisons to help you shop smarter.
    </p>
  </section>

  <div class="max-w-6xl mx-auto px-4 py-12">

    {featured.length > 0 && (
      <section class="mb-14">
        <h2 class="text-2xl font-bold text-navy mb-6">Featured</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {featured.map(post => (
            <a href={`/posts/${post.id}/`} class="group block rounded-xl border border-gray-100 hover:shadow-md transition-shadow overflow-hidden">
              {post.data.image && (
                <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} class="w-full h-44 object-cover" />
              )}
              <div class="p-4">
                <span class="text-xs font-semibold uppercase tracking-wide text-orange-start">{post.data.category}</span>
                <h3 class="font-bold mt-1 group-hover:text-navy transition-colors">{post.data.title}</h3>
                {post.data.description && <p class="text-sm text-gray-500 mt-1 line-clamp-2">{post.data.description}</p>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {latest.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold text-navy mb-6">Latest Comparisons</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {latest.map(post => (
            <a href={`/posts/${post.id}/`} class="group block rounded-xl border border-gray-100 hover:shadow-md transition-shadow overflow-hidden">
              {post.data.image && (
                <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} class="w-full h-40 object-cover" />
              )}
              <div class="p-4">
                <span class="text-xs font-semibold uppercase tracking-wide text-orange-start">{post.data.category}</span>
                <h3 class="font-bold mt-1 group-hover:text-navy transition-colors">{post.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {allPosts.length === 0 && (
      <p class="text-gray-400 text-center py-20">Content coming soon.</p>
    )}

  </div>
</BaseLayout>
