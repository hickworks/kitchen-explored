---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sorted = [...allPosts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Blog hero
const heroPost = sorted.find(p => p.data.featured) ?? sorted[0];
const heroListPosts = sorted.filter(p => p !== heroPost).slice(0, 4);

// Category sections — defined order with subtitles matching the design
const sectionDefs = [
  { label: 'Blenders',         slug: 'blenders',       subtitle: 'Best blenders for every kitchen and budget.',          layout: '2col' as const },
  { label: 'Cookware',         slug: 'cookware',        subtitle: 'Top cookware picks for home chefs.',                   layout: '3col' as const },
  { label: 'Knives',           slug: 'knives',          subtitle: 'Kitchen knife comparisons and buying guides.',         layout: '2col' as const },
  { label: 'Ovens',            slug: 'ovens',           subtitle: 'Oven comparisons and buying guides.',                  layout: '2col' as const },
  { label: 'Faucets',          slug: 'faucet',          subtitle: 'Kitchen faucet reviews and comparisons.',              layout: '2col' as const },
  { label: 'Pressure Cookers', slug: 'pressure-cooker', subtitle: 'Pressure cooker and multi-cooker comparisons.',        layout: '2col' as const },
];

const sections = sectionDefs
  .map(def => ({
    ...def,
    posts: sorted.filter(p => p.data.category === def.slug),
  }))
  .filter(s => s.posts.length > 0);

// Keep Reading: first 2 populated categories
const keepReading = sections.slice(0, 2);

const categories = [
  { label: 'Blenders',         slug: 'blenders' },
  { label: 'Cookware',         slug: 'cookware' },
  { label: 'Faucets',          slug: 'faucet' },
  { label: 'Ovens',            slug: 'ovens' },
  { label: 'Knives',           slug: 'knives' },
  { label: 'Pressure Cookers', slug: 'pressure-cooker' },
];

const toLabel = (s: string) => s.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
const toDate  = (d: Date)   => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout
  title="Home"
  description="Kitchen product comparisons and reviews — blenders, cookware, knives, ovens, and more."
>

  <!-- ── Site Hero ─────────────────────────────────────────────────── -->
  <section class="bg-navy py-20 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
        Every Kitchen Appliance, Compared.
      </h1>
      <p class="text-white/70 text-lg mb-8">
        Side-by-side comparisons to help you shop smarter.
      </p>
      <div class="flex gap-3 max-w-sm mx-auto">
        <input
          type="search"
          placeholder="Search comparisons…"
          class="flex-1 h-11 px-4 rounded-lg border border-white/20 bg-white/10 text-white placeholder:text-white/50 text-sm focus:outline-none focus:border-white/40"
        />
        <button
          class="h-11 px-5 rounded-lg text-white font-semibold text-sm whitespace-nowrap shrink-0"
          style="background:linear-gradient(135deg,#f78745,#f85026)"
        >
          Subscribe
        </button>
      </div>
    </div>
  </section>

  {sorted.length > 0 && (
    <>
      <!-- ── Blog Hero ────────────────────────────────────────────────── -->
      <section class="py-16 border-b border-gray-100">
        <div class="max-w-[1104px] mx-auto px-6">
          <div class="flex flex-col lg:flex-row gap-12 items-start">

            {/* Large featured card */}
            {heroPost && (
              <a
                href={`/posts/${heroPost.id}/`}
                class="group flex-1 min-w-0 block rounded-xl overflow-hidden border border-gray-100 bg-white hover:shadow-md transition-shadow"
              >
                <div class="h-[260px] bg-gray-100 overflow-hidden">
                  {heroPost.data.image
                    ? <img src={heroPost.data.image} alt={heroPost.data.imageAlt ?? heroPost.data.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300" />
                    : <div class="w-full h-full bg-gray-200" />
                  }
                </div>
                <div class="p-6 flex flex-col gap-3">
                  <span class="text-xs font-semibold uppercase tracking-wide text-orange-start">{toLabel(heroPost.data.category)}</span>
                  <h2 class="text-[22px] font-bold text-navy leading-snug line-clamp-2">{heroPost.data.title}</h2>
                  {heroPost.data.description && (
                    <p class="text-sm text-gray-500 line-clamp-2">{heroPost.data.description}</p>
                  )}
                  <div class="flex items-center gap-1.5 text-xs text-gray-400">
                    <div class="w-5 h-5 rounded-full bg-navy text-white flex items-center justify-center shrink-0" style="font-size:9px;font-weight:700">MH</div>
                    <span>Matt Hickman</span>
                    <span class="text-gray-200">·</span>
                    <time datetime={heroPost.data.pubDate.toISOString()}>{toDate(heroPost.data.pubDate)}</time>
                  </div>
                </div>
              </a>
            )}

            {/* Compact text list */}
            {heroListPosts.length > 0 && (
              <div class="w-full lg:w-[400px] shrink-0 flex flex-col">
                {heroListPosts.map(post => (
                  <a
                    href={`/posts/${post.id}/`}
                    class="group flex gap-3 py-4 border-b border-gray-100 hover:bg-gray-50 -mx-3 px-3 rounded transition-colors"
                  >
                    <div class="flex-1 min-w-0">
                      <span class="text-xs font-semibold uppercase tracking-wide text-orange-start">{toLabel(post.data.category)}</span>
                      <h3 class="mt-0.5 text-sm font-semibold text-gray-900 group-hover:text-navy transition-colors line-clamp-2 leading-snug">{post.data.title}</h3>
                      <p class="mt-1 text-xs text-gray-400">{toDate(post.data.pubDate)}</p>
                    </div>
                    <svg class="mt-1 shrink-0 text-gray-300 group-hover:text-navy transition-colors" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                ))}
                <a
                  href={heroPost ? `/category/${heroPost.data.category}/` : '/'}
                  class="mt-4 flex items-center justify-center h-10 rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:border-navy hover:text-navy transition-colors"
                >
                  Read All Posts
                </a>
              </div>
            )}

          </div>
        </div>
      </section>

      <!-- ── Filter Bar ───────────────────────────────────────────────── -->
      <div class="border-y border-gray-100 bg-white sticky top-0 z-10">
        <div class="max-w-[1104px] mx-auto px-6 h-[72px] flex items-center gap-6">
          <span class="text-sm font-medium text-gray-500 whitespace-nowrap shrink-0">Browse by category</span>
          <div class="flex items-center gap-1 overflow-x-auto">
            {categories.map(cat => (
              <a
                href={`/category/${cat.slug}/`}
                class="px-3 py-1.5 rounded-md text-sm text-gray-600 hover:text-navy hover:bg-gray-50 whitespace-nowrap transition-colors"
              >
                {cat.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- ── Category Sections ────────────────────────────────────────── -->
      {sections.map((section, i) => {
        const isGrayBg = i === 2; // Knives (3rd section) gets gray, matching design
        const is3Col   = section.layout === '3col';
        const featPost  = section.posts[0];
        const listPosts = section.posts.slice(1, 5);

        return (
          <section class:list={['py-16 border-t border-gray-100', isGrayBg ? 'bg-gray-50' : 'bg-white']}>
            <div class="max-w-[1104px] mx-auto px-6">

              {/* Section header */}
              <div class="mb-8">
                <h2 class="text-[40px] font-bold text-navy leading-none">{section.label}</h2>
                <div class="flex items-center justify-between mt-2">
                  <p class="text-sm text-gray-400">{section.subtitle}</p>
                  <a href={`/category/${section.slug}/`} class="text-sm font-medium text-orange-start hover:underline whitespace-nowrap ml-6">
                    Read More →
                  </a>
                </div>
              </div>

              {is3Col ? (
                /* 3-col post grid */
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                  {section.posts.slice(0, 3).map(post => <PostCard post={post} />)}
                </div>
              ) : (
                /* 2-col: featured card + text list */
                <div class="flex flex-col lg:flex-row gap-12 items-start">

                  {/* Featured card */}
                  <a
                    href={`/posts/${featPost.id}/`}
                    class="group flex-1 min-w-0 block rounded-xl overflow-hidden border border-gray-100 bg-white hover:shadow-md transition-shadow"
                  >
                    <div class="h-[260px] bg-gray-100 overflow-hidden">
                      {featPost.data.image
                        ? <img src={featPost.data.image} alt={featPost.data.imageAlt ?? featPost.data.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300" />
                        : <div class="w-full h-full bg-gray-200" />
                      }
                    </div>
                    <div class="p-6 flex flex-col gap-3">
                      <span class="text-xs font-semibold uppercase tracking-wide text-orange-start">{section.label}</span>
                      <h3 class="text-[22px] font-bold text-navy leading-snug line-clamp-2">{featPost.data.title}</h3>
                      {featPost.data.description && (
                        <p class="text-sm text-gray-500 line-clamp-2">{featPost.data.description}</p>
                      )}
                      <div class="flex items-center gap-1.5 text-xs text-gray-400">
                        <div class="w-5 h-5 rounded-full bg-navy text-white flex items-center justify-center shrink-0" style="font-size:9px;font-weight:700">MH</div>
                        <span>Matt Hickman</span>
                        <span class="text-gray-200">·</span>
                        <time datetime={featPost.data.pubDate.toISOString()}>{toDate(featPost.data.pubDate)}</time>
                      </div>
                    </div>
                  </a>

                  {/* Text list */}
                  {listPosts.length > 0 && (
                    <div class="w-full lg:w-[400px] shrink-0 flex flex-col">
                      {listPosts.map(post => (
                        <a
                          href={`/posts/${post.id}/`}
                          class="group flex gap-3 py-4 border-b border-gray-100 hover:bg-gray-50 -mx-3 px-3 rounded transition-colors"
                        >
                          <div class="flex-1 min-w-0">
                            <span class="text-xs font-semibold uppercase tracking-wide text-orange-start">{section.label}</span>
                            <h4 class="mt-0.5 text-sm font-semibold text-gray-900 group-hover:text-navy transition-colors line-clamp-2 leading-snug">{post.data.title}</h4>
                            <p class="mt-1 text-xs text-gray-400">{toDate(post.data.pubDate)}</p>
                          </div>
                          <svg class="mt-1 shrink-0 text-gray-300 group-hover:text-navy transition-colors" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
                        </a>
                      ))}
                      <a
                        href={`/category/${section.slug}/`}
                        class="mt-4 flex items-center justify-center h-10 rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:border-navy hover:text-navy transition-colors"
                      >
                        Read All Posts
                      </a>
                    </div>
                  )}

                </div>
              )}

            </div>
          </section>
        );
      })}

      <!-- ── Keep Reading ─────────────────────────────────────────────── -->
      {keepReading.length >= 2 && (
        <section class="border-t border-gray-100 grid grid-cols-1 lg:grid-cols-2">
          {keepReading.map((section, i) => (
            <div class:list={['py-16 px-12', i === 1 && 'border-t lg:border-t-0 lg:border-l border-gray-100']}>

              <div class="flex items-center justify-between mb-6">
                <div>
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">Keep Reading</p>
                  <h2 class="text-2xl font-bold text-navy">{section.label}</h2>
                </div>
                <a href={`/category/${section.slug}/`} class="text-sm font-medium text-orange-start hover:underline whitespace-nowrap ml-6">
                  Read More →
                </a>
              </div>

              <div class="flex flex-col">
                {section.posts.slice(0, 4).map(post => (
                  <a
                    href={`/posts/${post.id}/`}
                    class="group flex gap-3 py-3.5 border-b border-gray-100 last:border-0 hover:bg-gray-50 -mx-3 px-3 rounded transition-colors"
                  >
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-gray-900 group-hover:text-navy transition-colors line-clamp-2 leading-snug">{post.data.title}</p>
                      <p class="mt-0.5 text-xs text-gray-400">{toDate(post.data.pubDate)}</p>
                    </div>
                    <svg class="mt-0.5 shrink-0 text-gray-300 group-hover:text-navy transition-colors" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                ))}
              </div>

            </div>
          ))}
        </section>
      )}
    </>
  )}

  {sorted.length === 0 && (
    <section class="py-32 text-center text-gray-300">
      <p class="text-lg">Content coming soon.</p>
    </section>
  )}

  <!-- ── CTA Newsletter ───────────────────────────────────────────────── -->
  <section class="py-16 border-t border-gray-100">
    <div class="max-w-[680px] mx-auto px-6">
      <div class="rounded-2xl bg-navy p-12 text-center">
        <h2 class="text-3xl font-bold text-white mb-3">Stay in the loop.</h2>
        <p class="text-white/70 text-base mb-6">
          Get our latest kitchen product comparisons delivered to your inbox.
        </p>
        <div class="flex gap-3 max-w-sm mx-auto">
          <input
            type="email"
            placeholder="Email address"
            class="flex-1 h-11 px-4 rounded-lg border border-white/20 bg-white/10 text-white placeholder:text-white/50 text-sm focus:outline-none focus:border-white/40"
          />
          <button
            class="h-11 px-5 rounded-lg text-white font-semibold text-sm whitespace-nowrap shrink-0"
            style="background:linear-gradient(135deg,#f78745,#f85026)"
          >
            Subscribe
          </button>
        </div>
        <p class="mt-3 text-xs text-white/40">No spam. Unsubscribe any time.</p>
      </div>
    </div>
  </section>

</BaseLayout>
