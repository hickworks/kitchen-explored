---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sorted = [...allPosts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Blog hero
const heroPost = sorted.find(p => p.data.featured) ?? sorted[0];
const heroListPosts = sorted.filter(p => p !== heroPost).slice(0, 4);

// Category sections — defined order with subtitles matching the design
const sectionDefs = [
  { label: 'Blenders',         slug: 'blenders',       subtitle: 'Best blenders for every kitchen and budget.',          layout: '2col' as const },
  { label: 'Cookware',         slug: 'cookware',        subtitle: 'Top cookware picks for home chefs.',                   layout: '3col' as const },
  { label: 'Knives',           slug: 'knives',          subtitle: 'Kitchen knife comparisons and buying guides.',         layout: '2col' as const },
  { label: 'Ovens',            slug: 'ovens',           subtitle: 'Oven comparisons and buying guides.',                  layout: '2col' as const },
  { label: 'Faucets',          slug: 'faucet',          subtitle: 'Kitchen faucet reviews and comparisons.',              layout: '2col' as const },
  { label: 'Pressure Cookers', slug: 'pressure-cooker', subtitle: 'Pressure cooker and multi-cooker comparisons.',        layout: '2col' as const },
];

const sections = sectionDefs
  .map(def => ({
    ...def,
    posts: sorted.filter(p => p.data.category === def.slug),
  }))
  .filter(s => s.posts.length > 0);

// Keep Reading: first 2 populated categories
const keepReading = sections.slice(0, 2);

const categories = [
  { label: 'Blenders',         slug: 'blenders' },
  { label: 'Cookware',         slug: 'cookware' },
  { label: 'Faucets',          slug: 'faucet' },
  { label: 'Ovens',            slug: 'ovens' },
  { label: 'Knives',           slug: 'knives' },
  { label: 'Pressure Cookers', slug: 'pressure-cooker' },
];

const toLabel = (s: string) => s.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
const toDate  = (d: Date)   => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout
  title="Home"
  description="Kitchen Explored offers honest, in-depth product comparisons for home cooks — blenders, cookware, knives, ovens, faucets, and pressure cookers."
>

  <!-- ── Site Hero ─────────────────────────────────────────────────── -->
  <section class="bg-white py-16 border-b border-gray-100">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
      <h1 class="text-[56px] md:text-[64px] font-bold leading-tight mb-7 text-navy">
        Every Kitchen Appliance, Compared.
      </h1>
      <p class="text-lg text-gray-500 mb-7 max-w-[560px]">
        Independent head-to-head tests across blenders, cookware sets, chef's knives, pressure cookers, and ovens — so you can stop guessing and buy the right kitchen gear the first time.
      </p>
      <form class="flex items-center gap-3" data-subscribe>
        <input
          type="email"
          name="email"
          required
          placeholder="Enter your email"
          class="h-11 w-[280px] px-4 rounded-lg border border-gray-200 bg-white text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-navy"
        />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <button
          type="submit"
          class="h-11 px-5 rounded-lg text-white font-semibold text-sm whitespace-nowrap"
          style="background:linear-gradient(135deg,#f78745,#f85026)"
        >
          Subscribe
        </button>
        <span class="text-sm text-green-600 font-medium hidden" data-success>You're in!</span>
      </form>
    </div>
  </section>

  {sorted.length > 0 && (
    <>
      <!-- ── Blog Hero ────────────────────────────────────────────────── -->
      <section class="py-16 border-b border-gray-100">
        <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
          <div class="flex flex-col lg:flex-row gap-12 items-start">

            {/* Large featured card */}
            {heroPost && (
              <a
                href={`/posts/${heroPost.id}/`}
                class="group flex-1 min-w-0 block rounded-xl overflow-hidden border border-gray-100 bg-white hover:shadow-md transition-shadow"
              >
                <div class="h-[260px] bg-gray-100 overflow-hidden">
                  {heroPost.data.image
                    ? <img src={heroPost.data.image} alt={heroPost.data.imageAlt ?? heroPost.data.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300" />
                    : <div class="w-full h-full bg-gray-200" />
                  }
                </div>
                <div class="p-6 flex flex-col gap-3">
                  <span class="text-xs font-semibold uppercase tracking-wide text-orange-text">{toLabel(heroPost.data.category)}</span>
                  <h2 class="text-[22px] font-bold text-navy leading-snug line-clamp-2">{heroPost.data.title}</h2>
                  {heroPost.data.description && (
                    <p class="text-sm text-gray-500 line-clamp-2">{heroPost.data.description}</p>
                  )}
                  <div class="flex items-center gap-1.5 text-xs text-gray-500">
                    <div class="w-5 h-5 rounded-full bg-navy text-white flex items-center justify-center shrink-0" style="font-size:9px;font-weight:700">MH</div>
                    <span>Matt Hickman</span>
                    <span class="text-gray-200">·</span>
                    <time datetime={heroPost.data.pubDate.toISOString()}>{toDate(heroPost.data.pubDate)}</time>
                  </div>
                </div>
              </a>
            )}

            {/* Compact text list */}
            {heroListPosts.length > 0 && (
              <div class="w-full lg:w-[400px] shrink-0 flex flex-col">
                {heroListPosts.map(post => (
                  <a
                    href={`/posts/${post.id}/`}
                    class="group flex gap-3 py-4 border-b border-gray-100 hover:bg-gray-50 -mx-3 px-3 rounded transition-colors"
                  >
                    <div class="flex-1 min-w-0">
                      <span class="text-xs font-semibold uppercase tracking-wide text-orange-text">{toLabel(post.data.category)}</span>
                      <h3 class="mt-0.5 text-sm font-semibold text-gray-900 group-hover:text-navy transition-colors line-clamp-2 leading-snug">{post.data.title}</h3>
                      <p class="mt-1 text-xs text-gray-500">{toDate(post.data.pubDate)}</p>
                    </div>
                    <svg class="mt-1 shrink-0 text-gray-300 group-hover:text-navy transition-colors" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                ))}
                <a
                  href={heroPost ? `/category/${heroPost.data.category}/` : '/'}
                  aria-label={heroPost ? `Read all ${toLabel(heroPost.data.category)} posts` : 'Read all posts'}
                  class="mt-4 flex items-center justify-center h-10 rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:border-navy hover:text-navy transition-colors"
                >
                  Read All Posts
                </a>
              </div>
            )}

          </div>
        </div>
      </section>

      <!-- ── Filter Bar ───────────────────────────────────────────────── -->
      <div class="border-y border-gray-100 bg-white sticky top-0 z-10">
        <div class="max-w-[1440px] mx-auto px-6 lg:px-12 h-[72px] flex items-center justify-between gap-6">
          <span class="text-base font-bold text-navy whitespace-nowrap shrink-0">Browse by category</span>
          <div class="flex items-center gap-1 overflow-x-auto">
            {categories.map(cat => (
              <a
                href={`/category/${cat.slug}/`}
                class="px-3 py-1.5 rounded-md text-sm text-gray-600 hover:text-navy hover:bg-gray-50 whitespace-nowrap transition-colors"
              >
                {cat.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- ── Category Sections ────────────────────────────────────────── -->
      {sections.map((section, i) => {
        const isGrayBg = i === 2; // Knives (3rd section) gets gray, matching design
        const is3Col   = section.layout === '3col';
        const featPost  = section.posts[0];
        const listPosts = section.posts.slice(1, 5);

        return (
          <section class:list={['py-16 border-t border-gray-100', isGrayBg ? 'bg-gray-50' : 'bg-white']}>
            <div class="max-w-[1440px] mx-auto px-6 lg:px-12">

              {/* Section header */}
              <div class="mb-8">
                <h2 class="text-[40px] font-bold text-navy leading-none">{section.label}</h2>
                <div class="flex items-center justify-between mt-2">
                  <p class="text-sm text-gray-500">{section.subtitle}</p>
                  <a href={`/category/${section.slug}/`} class="text-sm font-medium text-orange-text hover:underline whitespace-nowrap ml-6">
                    Read More<span class="sr-only"> {section.label}</span> →
                  </a>
                </div>
              </div>

              {is3Col ? (
                /* 3-col post grid */
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                  {section.posts.slice(0, 3).map(post => <PostCard post={post} />)}
                </div>
              ) : (
                /* 2-col: featured card + text list */
                <div class="flex flex-col lg:flex-row gap-12 items-start">

                  {/* Featured card */}
                  <a
                    href={`/posts/${featPost.id}/`}
                    class="group flex-1 min-w-0 block rounded-xl overflow-hidden border border-gray-100 bg-white hover:shadow-md transition-shadow"
                  >
                    <div class="h-[260px] bg-gray-100 overflow-hidden">
                      {featPost.data.image
                        ? <img src={featPost.data.image} alt={featPost.data.imageAlt ?? featPost.data.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300" />
                        : <div class="w-full h-full bg-gray-200" />
                      }
                    </div>
                    <div class="p-6 flex flex-col gap-3">
                      <span class="text-xs font-semibold uppercase tracking-wide text-orange-text">{section.label}</span>
                      <h3 class="text-[22px] font-bold text-navy leading-snug line-clamp-2">{featPost.data.title}</h3>
                      {featPost.data.description && (
                        <p class="text-sm text-gray-500 line-clamp-2">{featPost.data.description}</p>
                      )}
                      <div class="flex items-center gap-1.5 text-xs text-gray-500">
                        <div class="w-5 h-5 rounded-full bg-navy text-white flex items-center justify-center shrink-0" style="font-size:9px;font-weight:700">MH</div>
                        <span>Matt Hickman</span>
                        <span class="text-gray-200">·</span>
                        <time datetime={featPost.data.pubDate.toISOString()}>{toDate(featPost.data.pubDate)}</time>
                      </div>
                    </div>
                  </a>

                  {/* Text list */}
                  {listPosts.length > 0 && (
                    <div class="w-full lg:w-[400px] shrink-0 flex flex-col">
                      {listPosts.map(post => (
                        <a
                          href={`/posts/${post.id}/`}
                          class="group flex gap-3 py-4 border-b border-gray-100 hover:bg-gray-50 -mx-3 px-3 rounded transition-colors"
                        >
                          <div class="flex-1 min-w-0">
                            <span class="text-xs font-semibold uppercase tracking-wide text-orange-text">{section.label}</span>
                            <h4 class="mt-0.5 text-sm font-semibold text-gray-900 group-hover:text-navy transition-colors line-clamp-2 leading-snug">{post.data.title}</h4>
                            <p class="mt-1 text-xs text-gray-500">{toDate(post.data.pubDate)}</p>
                          </div>
                          <svg class="mt-1 shrink-0 text-gray-300 group-hover:text-navy transition-colors" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
                        </a>
                      ))}
                      <a
                        href={`/category/${section.slug}/`}
                        aria-label={`Read all ${section.label} posts`}
                        class="mt-4 flex items-center justify-center h-10 rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:border-navy hover:text-navy transition-colors"
                      >
                        Read All Posts
                      </a>
                    </div>
                  )}

                </div>
              )}

            </div>
          </section>
        );
      })}

      <!-- ── Keep Reading ─────────────────────────────────────────────── -->
      {keepReading.length >= 2 && (
        <section class="py-16 border-t border-gray-100">
          <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
            <div class="bg-gray-50 rounded-2xl overflow-hidden grid grid-cols-1 lg:grid-cols-2 divide-y lg:divide-y-0 lg:divide-x divide-gray-200">
              {keepReading.map((section) => (
                <div class="p-8 lg:p-10">

                  <div class="flex items-center justify-between mb-6">
                    <h2 class="text-lg font-semibold text-gray-500">
                      Keep Reading <span class="text-navy font-bold">{section.label}</span>
                    </h2>
                    <a
                      href={`/category/${section.slug}/`}
                      class="shrink-0 ml-4 px-3 py-1.5 rounded-lg border border-gray-300 text-xs font-medium text-gray-700 hover:border-navy hover:text-navy transition-colors"
                    >
                      Read More<span class="sr-only"> {section.label}</span>
                    </a>
                  </div>

                  <div class="flex flex-col">
                    {section.posts.slice(0, 4).map(post => (
                      <a
                        href={`/posts/${post.id}/`}
                        class="group flex items-center gap-3 py-3 border-b border-gray-200 last:border-0 hover:opacity-75 transition-opacity"
                      >
                        <div class="w-12 h-12 rounded-lg overflow-hidden shrink-0 bg-gray-200">
                          {post.data.image && (
                            <img src={post.data.image} alt="" class="w-full h-full object-cover" />
                          )}
                        </div>
                        <p class="flex-1 min-w-0 text-sm font-semibold text-gray-900 group-hover:text-navy transition-colors line-clamp-2 leading-snug">{post.data.title}</p>
                        <svg class="shrink-0 text-gray-300 group-hover:text-navy transition-colors" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
                      </a>
                    ))}
                  </div>

                </div>
              ))}
            </div>
          </div>
        </section>
      )}
    </>
  )}

  {sorted.length === 0 && (
    <section class="py-32 text-center text-gray-300">
      <p class="text-lg">Content coming soon.</p>
    </section>
  )}

  <!-- ── CTA Newsletter ───────────────────────────────────────────────── -->
  <section id="newsletter" class="py-16 border-t border-gray-100">
    <div class="max-w-[680px] mx-auto px-6">
      <div class="rounded-2xl bg-navy p-12 text-center">
        <h2 class="text-3xl font-bold text-white mb-3">Stay in the loop.</h2>
        <p class="text-white/70 text-base mb-6">
          Get our latest kitchen product comparisons delivered to your inbox.
        </p>
        <form class="flex gap-3 max-w-sm mx-auto" data-subscribe>
          <input
            type="email"
            name="email"
            required
            placeholder="Email address"
            class="flex-1 h-11 px-4 rounded-lg border border-white/20 bg-white/10 text-white placeholder:text-white/50 text-sm focus:outline-none focus:border-white/40"
          />
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
          <button
            type="submit"
            class="h-11 px-5 rounded-lg text-white font-semibold text-sm whitespace-nowrap shrink-0"
            style="background:linear-gradient(135deg,#f78745,#f85026)"
          >
            Subscribe
          </button>
        </form>
        <p class="mt-3 text-xs text-white/60" data-newsletter-status>No spam. Unsubscribe any time.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const WORKER = 'https://kitchen-explored-contact.matt-d9d.workers.dev/subscribe';

  document.querySelectorAll<HTMLFormElement>('form[data-subscribe]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const successSpan = form.querySelector('[data-success]') as HTMLElement | null;
      const statusP = document.querySelector('[data-newsletter-status]') as HTMLElement | null;

      btn.disabled = true;
      btn.textContent = '…';

      try {
        const res = await fetch(WORKER, {
          method: 'POST',
          body: new FormData(form),
        });
        const data = await res.json();

        if (data.ok) {
          form.reset();
          btn.textContent = '✓';
          if (successSpan) {
            successSpan.classList.remove('hidden');
          }
          if (statusP) {
            statusP.textContent = "You're subscribed — thanks!";
            statusP.classList.add('!text-white/80');
          }
        } else {
          throw new Error(data.error);
        }
      } catch {
        btn.disabled = false;
        btn.textContent = 'Subscribe';
        if (statusP) statusP.textContent = 'Something went wrong. Please try again.';
        alert('Something went wrong. Please try again.');
      }
    });
  });
</script>
