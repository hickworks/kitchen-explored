---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const { title, description, pubDate, updatedDate, category, image, imageAlt } = post.data;

const allPosts = await getCollection('posts');
const related = allPosts
  .filter(p => p.data.category === category && p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const categoryLabel = category.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
const toc = headings.filter(h => h.depth <= 3);
const readTime = Math.max(1, Math.ceil((post.body ?? '').split(/\s+/).length / 200));

const dateStr = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  ...(image && { image: new URL(image, Astro.site).toString() }),
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Matt Hickman',
    url: new URL('/about/', Astro.site).toString(),
  },
  publisher: {
    '@type': 'Organization',
    name: 'Kitchen Explored',
    url: Astro.site?.toString(),
  },
};
---

<BaseLayout title={title} description={description} activeCategory={category} image={image} ogType="article" schema={articleSchema}>

  <!-- Article Header -->
  <div class="border-b border-gray-100">
    <div class="max-w-[1344px] mx-auto px-6 lg:px-12 py-12">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-sm text-gray-400 mb-6">
        <a href="/" class="hover:text-navy transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <a href={`/category/${category}/`} class="hover:text-navy transition-colors">{categoryLabel}</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-gray-600 truncate max-w-xs">{title}</span>
      </nav>

      <!-- Category + date -->
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold uppercase tracking-wide text-orange-start">{categoryLabel}</span>
        <span class="text-gray-300">·</span>
        <time class="text-sm text-gray-400" datetime={pubDate.toISOString()}>{dateStr}</time>
        {updatedStr && (
          <>
            <span class="text-gray-300">·</span>
            <span class="text-sm text-gray-400">Updated {updatedStr}</span>
          </>
        )}
      </div>

      <!-- Title -->
      <h1 class="text-3xl md:text-[40px] font-bold text-navy leading-tight mb-4">{title}</h1>

      <!-- Description / subtitle -->
      {description && (
        <p class="text-lg text-gray-500 mb-6 leading-relaxed">{description}</p>
      )}

      <!-- PostMeta -->
      <div class="flex items-center gap-2 text-sm text-gray-400 mb-8">
        <div class="w-8 h-8 rounded-full bg-navy text-white flex items-center justify-center shrink-0" style="font-size:11px;font-weight:700">MH</div>
        <span class="font-medium text-gray-700">Matt Hickman</span>
        <span class="text-gray-200">·</span>
        <span>{readTime} min read</span>
      </div>

      <!-- Hero image -->
      {image && (
        <img
          src={image}
          alt={imageAlt ?? title}
          class="w-full rounded-xl object-cover max-h-[450px]"
          loading="eager"
          fetchpriority="high"
        />
      )}

    </div>
  </div>

  <!-- Content + ToC -->
  <div class="max-w-[1344px] mx-auto px-6 lg:px-12 py-12">
    <div class="flex gap-16 items-start">

      <!-- Sticky ToC -->
      {toc.length > 0 && (
        <aside class="hidden xl:block w-56 shrink-0 sticky top-8">
          <div class="rounded-xl border border-gray-100 overflow-hidden text-sm">
            <div class="px-4 py-3 bg-gray-50 border-b border-gray-100">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Contents</p>
            </div>
            {toc.map((h, i) => (
              <a
                href={`#${h.slug}`}
                class:list={[
                  'flex items-start gap-2 px-4 py-2.5 text-sm border-b border-gray-50 hover:bg-gray-50 transition-colors',
                  h.depth === 2 ? 'font-medium text-gray-800' : 'pl-7 text-gray-500',
                ]}
              >
                {h.depth === 2 && <span class="text-gray-300 shrink-0 font-normal tabular-nums">{i + 1}.</span>}
                <span class="leading-snug">{h.text}</span>
              </a>
            ))}
          </div>
        </aside>
      )}

      <!-- Article body -->
      <div class="min-w-0 flex-1">

        <!-- Summary box -->
        {description && (
          <div class="rounded-lg bg-slate-50 border border-gray-100 p-6 mb-8">
            <p class="text-xs font-semibold text-navy uppercase tracking-wide mb-2">Summary</p>
            <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
          </div>
        )}

        <div class="prose prose-lg max-w-none
          prose-headings:text-navy prose-headings:font-bold
          prose-a:text-orange-start prose-a:no-underline hover:prose-a:underline
          prose-strong:text-gray-900
          prose-table:text-sm
          prose-th:bg-gray-50 prose-th:text-navy prose-th:font-semibold
          prose-td:align-top">
          <Content />
        </div>

      </div>
    </div>
  </div>

  <!-- CTA Banner -->
  <div class="bg-navy py-8 px-6">
    <div class="max-w-[1344px] mx-auto px-6 lg:px-12 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-5 shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" stroke="#f78745" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        <div>
          <p class="text-white font-bold text-lg leading-tight">Get our weekly kitchen comparison digest.</p>
          <p class="text-white/60 text-sm">No fluff — just the best picks for home cooks.</p>
        </div>
      </div>
      <form class="flex items-center gap-2 w-full sm:w-auto" data-subscribe>
        <input
          type="email"
          name="email"
          required
          placeholder="Your email address"
          class="flex-1 sm:w-56 h-10 px-4 rounded-lg border border-white/20 bg-white/10 text-white placeholder:text-white/50 text-sm focus:outline-none focus:border-white/40"
        />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <button
          type="submit"
          class="shrink-0 h-10 px-5 rounded-lg !text-white font-semibold text-sm whitespace-nowrap"
          style="background:linear-gradient(135deg,#f78745,#f85026)"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>

  <!-- Author Bio -->
  <div class="border-b border-gray-100">
    <div class="max-w-[1344px] mx-auto px-6 lg:px-12 py-10 flex items-start gap-5">
      <div class="w-14 h-14 rounded-full bg-navy text-white flex items-center justify-center shrink-0 text-base font-bold">MH</div>
      <div>
        <p class="font-bold text-gray-900">Matt Hickman</p>
        <p class="text-sm text-gray-500 mb-2">Kitchen Appliance Reviewer</p>
        <p class="text-sm text-gray-600 leading-relaxed">
          Matt has tested over 200 kitchen appliances since 2018. He focuses on real-world usability, durability, and value for everyday home cooks.
        </p>
      </div>
    </div>
  </div>

  <!-- Related Articles -->
  {related.length > 0 && (
    <section class="py-12 bg-gray-50">
      <div class="max-w-[1344px] mx-auto px-6 lg:px-12">
        <h2 class="text-2xl font-bold text-navy mb-1">Related Articles</h2>
        <div class="h-px bg-gray-100 mb-6" />
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {related.map(p => <PostCard post={p} />)}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<script>
  const WORKER = 'https://kitchen-explored-contact.matt-d9d.workers.dev/subscribe';

  document.querySelectorAll<HTMLFormElement>('form[data-subscribe]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = '…';

      try {
        const res = await fetch(WORKER, { method: 'POST', body: new FormData(form) });
        const data = await res.json();
        if (data.ok) {
          form.innerHTML = '<p class="text-white font-semibold text-sm">You\'re subscribed — thanks!</p>';
        } else {
          throw new Error(data.error);
        }
      } catch {
        btn.disabled = false;
        btn.textContent = 'Subscribe';
      }
    });
  });
</script>
