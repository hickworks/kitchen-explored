---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Kitchen Explored.">

  <div class="max-w-2xl mx-auto px-6 py-16">
    <nav class="flex items-center gap-1.5 text-sm text-gray-400 mb-8">
      <a href="/" class="hover:text-navy transition-colors">Home</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-gray-600">Contact</span>
    </nav>

    <h1 class="text-4xl font-bold text-navy mb-4">Contact Us</h1>
    <p class="text-gray-500 text-lg mb-10">
      Have a question, a product suggestion, or just want to say hello?
    </p>

    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-4 p-5 rounded-xl border border-gray-100 hover:border-gray-200 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-navy/5 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="#062451" stroke-width="2" viewBox="0 0 24 24"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-900">Email</p>
          <a href="mailto:hello@kitchenexplored.com" class="text-sm text-orange-start hover:underline">
            hello@kitchenexplored.com
          </a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
