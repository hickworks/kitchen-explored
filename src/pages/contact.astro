---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Kitchen Explored.">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-navy mb-6">Contact Us</h1>
    <p class="text-gray-600">
      Have a question or suggestion? Reach out at
      <a href="mailto:hello@kitchenexplored.com" class="text-orange-start hover:underline">
        hello@kitchenexplored.com
      </a>.
    </p>
  </div>
</BaseLayout>
