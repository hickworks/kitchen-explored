---
import BaseLayout from '../layouts/BaseLayout.astro';

// After deploying the Cloudflare Worker (workers/contact-form/),
// replace this with your Worker URL, e.g.:
// https://kitchen-explored-contact.YOUR_SUBDOMAIN.workers.dev
const WORKER_URL = 'https://kitchen-explored-contact.matt-d9d.workers.dev';
---

<BaseLayout title="Contact Kitchen Explored" description="Get in touch with Kitchen Explored. Product suggestions, questions, or just to say hello.">

  <!-- Hero -->
  <section class="bg-navy py-20 px-6">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
      <p class="text-orange-start text-sm font-semibold uppercase tracking-widest mb-4">Contact</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight max-w-2xl mb-6">
        Get in touch.
      </h1>
      <p class="text-white/60 text-lg max-w-xl leading-relaxed">
        Product suggestion, partnership inquiry, or just want to say hello. We read every message.
      </p>
    </div>
  </section>

  <!-- Main content -->
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Left: form -->
      <div class="lg:col-span-2">
        <form
          id="contact-form"
          action={WORKER_URL}
          method="POST"
          class="flex flex-col gap-5"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1.5">
              <label for="name" class="text-sm font-medium text-gray-700">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Jane Smith"
                class="h-11 px-4 rounded-lg border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-navy transition-colors"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-sm font-medium text-gray-700">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="jane@example.com"
                class="h-11 px-4 rounded-lg border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-navy transition-colors"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="subject" class="text-sm font-medium text-gray-700">Subject</label>
            <select
              id="subject"
              name="subject"
              class="h-11 px-4 rounded-lg border border-gray-200 text-sm text-gray-900 bg-white focus:outline-none focus:border-navy transition-colors"
            >
              <option value="product-suggestion">Product suggestion</option>
              <option value="question">Question about a comparison</option>
              <option value="partnership">Partnership or collaboration</option>
              <option value="correction">Correction or feedback</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-sm font-medium text-gray-700">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder="What's on your mind?"
              class="px-4 py-3 rounded-lg border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-navy transition-colors resize-none"
            ></textarea>
          </div>

          <!-- Success / error messages (shown via JS) -->
          <div id="form-success" class="hidden rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800 font-medium">
            Message sent. We'll get back to you soon.
          </div>
          <div id="form-error" class="hidden rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800 font-medium">
            Something went wrong. Please try emailing us directly.
          </div>

          <!-- Honeypot: hidden from humans, filled by bots -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

          <div>
            <button
              type="submit"
              id="submit-btn"
              class="px-6 py-2.5 rounded-lg text-white font-semibold text-sm whitespace-nowrap transition-opacity"
              style="background:linear-gradient(135deg,#f78745,#f85026)"
            >
              Send Message
            </button>
          </div>
        </form>
      </div>

      <!-- Right: contact info -->
      <div class="flex flex-col gap-6">

        <!-- Email -->
        <div class="rounded-xl border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-navy/5 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="#062451" stroke-width="2" viewBox="0 0 24 24"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <p class="text-sm font-semibold text-gray-900">Email us directly</p>
          </div>
          <a href="mailto:hello@kitchenexplored.com" class="text-sm text-orange-start hover:underline break-all">
            hello@kitchenexplored.com
          </a>
        </div>

        <!-- Response time -->
        <div class="rounded-xl border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-navy/5 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="#062451" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <p class="text-sm font-semibold text-gray-900">Response time</p>
          </div>
          <p class="text-sm text-gray-500 leading-relaxed">
            We aim to reply within 2–3 business days. For urgent matters, email directly.
          </p>
        </div>

        <!-- What to reach out about -->
        <div class="rounded-xl border border-gray-100 p-6">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Good reasons to write</p>
          <ul class="flex flex-col gap-2.5">
            {[
              'You want two products compared that we haven\'t covered',
              'You spot an error in one of our articles',
              'You want to collaborate or advertise',
              'You just have a kitchen question',
            ].map(item => (
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="#f78745" stroke-width="2.5" viewBox="0 0 24 24" class="shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </div>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg = document.getElementById('form-error')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch(form.getAttribute('action')!, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        successMsg.classList.remove('hidden');
        errorMsg.classList.add('hidden');
        submitBtn.textContent = 'Sent';
      } else {
        throw new Error('Non-OK response');
      }
    } catch {
      errorMsg.classList.remove('hidden');
      successMsg.classList.add('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
