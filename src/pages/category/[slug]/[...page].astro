---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import Pagination from '../../../components/Pagination.astro';
import { getCollection } from 'astro:content';

const LABELS: Record<string, string> = {
  blenders: 'Blenders',
  cookware: 'Cookware',
  faucet: 'Faucets',
  ovens: 'Ovens',
  knives: 'Knives',
  'pressure-cooker': 'Pressure Cookers',
};

const DESCRIPTIONS: Record<string, string> = {
  blenders: 'Browse in-depth blender comparisons and reviews. We test Vitamix, Ninja, NutriBullet, and more to help you find the right blender for your kitchen and budget.',
  cookware: 'Compare cookware brands and materials — stainless steel, nonstick, cast iron, and more. Find the best pots and pans for your cooking style and budget.',
  faucet: 'Compare kitchen faucets by style, finish, and functionality. Our reviews cover pull-down, pull-out, and touchless models to help you find the right fit.',
  ovens: 'Compare toaster ovens, convection ovens, and countertop ovens. Our reviews cover performance, capacity, and value to help you choose the right oven.',
  knives: 'Compare kitchen knives, chef\'s knives, and knife sets. Our reviews cover blade quality, handle comfort, and edge retention to help you cook better.',
  'pressure-cooker': 'Compare electric pressure cookers and Instant Pots. Our reviews cover capacity, programs, safety features, and value for every type of home cook.',
};

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allPosts = await getCollection('posts');
  const slugs = ['blenders', 'cookware', 'faucet', 'ovens', 'knives', 'pressure-cooker'];

  return slugs.flatMap(slug => {
    const posts = allPosts
      .filter(p => p.data.category === slug)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return paginate(posts, { params: { slug }, pageSize: 12 });
  });
}

const { slug } = Astro.params;
const { page } = Astro.props;
const label = LABELS[slug] ?? slug;
const baseUrl = `/category/${slug}/`;

const categories = [
  { label: 'Blenders', slug: 'blenders' },
  { label: 'Cookware', slug: 'cookware' },
  { label: 'Faucets', slug: 'faucet' },
  { label: 'Ovens', slug: 'ovens' },
  { label: 'Knives', slug: 'knives' },
  { label: 'Pressure Cookers', slug: 'pressure-cooker' },
];
---

<BaseLayout
  title={page.currentPage > 1 ? `${label} — Page ${page.currentPage}` : label}
  description={page.currentPage > 1
    ? `${DESCRIPTIONS[slug] ?? `${label} product comparisons and reviews.`} — Page ${page.currentPage} of ${page.lastPage}.`
    : (DESCRIPTIONS[slug] ?? `${label} product comparisons and reviews.`)}
  activeCategory={slug}
>

  <!-- Category header -->
  <div class="border-b border-gray-100 bg-white">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-12 py-10">
      <nav class="flex items-center gap-1.5 text-sm text-gray-400 mb-4">
        <a href="/" class="hover:text-navy transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-gray-700 font-medium">{label}</span>
      </nav>
      <h1 class="text-4xl font-bold text-navy">{label}</h1>
      {page.total > 0 && (
        <p class="mt-2 text-sm text-gray-400">
          {page.total} comparison{page.total !== 1 ? 's' : ''}
          {page.lastPage > 1 && ` — page ${page.currentPage} of ${page.lastPage}`}
        </p>
      )}
    </div>
  </div>

  <!-- Filter bar -->
  <div class="border-b border-gray-100 bg-white sticky top-0 z-10">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-12 h-[72px] flex items-center justify-between gap-6">
      <span class="text-base font-bold text-navy whitespace-nowrap shrink-0">Browse by category</span>
      <div class="flex items-center gap-1 overflow-x-auto">
        {categories.map(cat => (
          <a
            href={`/category/${cat.slug}/`}
            class:list={[
              'px-3 py-1.5 rounded-md text-sm whitespace-nowrap transition-colors',
              cat.slug === slug
                ? 'bg-navy text-white font-semibold'
                : 'text-gray-600 hover:text-navy hover:bg-gray-50',
            ]}
          >
            {cat.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Post grid -->
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12 py-12">
    {page.data.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {page.data.map((post: any) => <PostCard post={post} />)}
      </div>
    ) : (
      <div class="py-24 text-center">
        <p class="text-gray-400 text-lg">No comparisons in this category yet.</p>
        <p class="text-gray-300 text-sm mt-2">Check back soon.</p>
      </div>
    )}
  </div>

  <!-- Pagination -->
  <Pagination
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    baseUrl={baseUrl}
  />

</BaseLayout>
