---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = ['blenders', 'cookware', 'faucet', 'ovens', 'knives', 'pressure-cooker'];
  return categories.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.data.category === slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const label = slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
---

<BaseLayout title={label} description={`${label} product comparisons and reviews.`}>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-navy mb-8">{label}</h1>

    {posts.length > 0 ? (
      <div class="grid md:grid-cols-3 gap-6">
        {posts.map(post => (
          <a href={`/posts/${post.id}/`} class="group block rounded-xl border border-gray-100 hover:shadow-md transition-shadow overflow-hidden">
            {post.data.image && (
              <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} class="w-full h-40 object-cover" />
            )}
            <div class="p-4">
              <h2 class="font-bold group-hover:text-navy transition-colors">{post.data.title}</h2>
              {post.data.description && <p class="text-sm text-gray-500 mt-1 line-clamp-2">{post.data.description}</p>}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-gray-400">No posts in this category yet.</p>
    )}
  </div>
</BaseLayout>
