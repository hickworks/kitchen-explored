---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy" description="Kitchen Explored privacy policy.">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-navy mb-6">Privacy Policy</h1>
    <div class="prose prose-lg">
      <p>
        Kitchen Explored does not collect personal information beyond standard server logs. We may
        use affiliate links and analytics tools such as Google Analytics. Content will be updated
        as the site grows.
      </p>
    </div>
  </div>
</BaseLayout>
