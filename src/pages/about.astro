---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Us" description="Learn about Kitchen Explored.">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-navy mb-6">About Kitchen Explored</h1>
    <div class="prose prose-lg">
      <p>
        Kitchen Explored helps home cooks make confident purchasing decisions. We write detailed,
        side-by-side comparisons of blenders, cookware, knives, ovens, pressure cookers, and more.
      </p>
      <p>
        Our goal is to cut through marketing noise and give you the real differences between products.
      </p>
    </div>
  </div>
</BaseLayout>
